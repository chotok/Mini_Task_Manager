{% extends 'base.html.twig' %}

{% block title %}New Task{% endblock %}

{% block body %}

<h1>New Task</h1>

{{ form_start(form) }}

    {{ form_row(form.title) }}
    {{ form_row(form.description) }}
    {{ form_row(form.status) }}
    {{ form_row(form.createdAt) }}
    {{ form_row(form.updatedAt) }}
    {{ form_row(form.owner) }}
    {{ form_row(form.save) }}

{{ form_end(form) }}

{% endblock %}